generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String?           @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             String            @default("EMPLOYEE")
  isArchived       Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  startDate        DateTime?
  hourlyWage       Float             @default(13.90)
  accounts         Account[]
  documents        Document[]
  onboardingStatus OnboardingStatus?
  payslips         Payslip[]
  sessions              Session[]
  stepProgresses        StepProgress[]
  timesheets            Timesheet[]
  availabilityResponses AvailabilityResponse[]
  staffPlanRows         StaffPlanRow[]
}

model Payslip {
  id         String   @id @default(cuid())
  month      Int
  year       Int
  url        String
  uploadedAt DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OnboardingStatus {
  id        String   @id @default(cuid())
  userId    String   @unique
  status    String   @default("INVITED")
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StepProgress {
  id        String   @id @default(cuid())
  userId    String
  stepId    String
  completed Boolean  @default(false)
  data      String?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stepId])
}

model Document {
  id         String   @id @default(cuid())
  name       String
  url        String
  type       String
  userId     String?
  uploadedAt DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}

model Timesheet {
  id           String   @id @default(cuid())
  userId       String
  date         String   // E.g., 'YYYY-MM-DD'
  startTime    String   // E.g., '08:00'
  endTime      String   // E.g., '16:00'
  breakMinutes Int      @default(0)
  totalHours   Float
  status       String   @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED
  note         String?
  hourlyWage   Float?   // Fixed wage at submission time
  approvedBy   String?  // Name or ID of admin
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Benefit {
  id          String   @id @default(cuid())
  partnerName String
  partnerLogo String?
  websiteUrl  String?
  title       String
  description String
  discount    String?
  conditions  String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AvailabilityRequest {
  id        String            @id @default(cuid())
  title     String
  startDate DateTime
  endDate   DateTime
  status    String            @default("DRAFT") // DRAFT, PUBLISHED, CLOSED
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  days      AvailabilityDay[]
}

model AvailabilityDay {
  id          String                 @id @default(cuid())
  requestId   String
  date        DateTime
  eventName   String?
  note        String?
  request     AvailabilityRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  responses   AvailabilityResponse[]
  staffPlan   StaffPlanDay?

  @@unique([requestId, date])
}

model AvailabilityResponse {
  id         String          @id @default(cuid())
  employeeId String
  dayId      String
  status     String          // YES, NO, MAYBE
  comment    String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  day        AvailabilityDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@unique([employeeId, dayId])
}

model StaffPlanDay {
  id          String                @id @default(cuid())
  dayId       String?               @unique
  date        DateTime
  eventName   String?
  note        String?
  status      String                @default("DRAFT") // DRAFT, FINAL
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  day         AvailabilityDay?      @relation(fields: [dayId], references: [id], onDelete: SetNull)
  rows        StaffPlanRow[]
}

model StaffPlanRow {
  id              String        @id @default(cuid())
  planId          String
  sortOrder       Int           @default(0)
  assignmentLabel String        // z.B. "Beton Bar (Bar-Chef)", "Einlass", "CvD"
  employeeId      String?       // null = unbesetzte Position
  startTime       String?       // z.B. "22:00"
  endTime         String?       // z.B. "06:00"
  note            String?
  plan            StaffPlanDay  @relation(fields: [planId], references: [id], onDelete: Cascade)
  user            User?         @relation(fields: [employeeId], references: [id], onDelete: SetNull)
}

model ShiftTemplate {
  id        String              @id @default(cuid())
  name      String              @unique
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  rows      ShiftTemplateRow[]
}

model ShiftTemplateRow {
  id               String        @id @default(cuid())
  templateId       String
  sortOrder        Int           @default(0)
  assignmentLabel  String
  defaultStartTime String?
  template         ShiftTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}
